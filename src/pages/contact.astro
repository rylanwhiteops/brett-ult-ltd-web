---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.tsx';
import GHLForm from '../components/GHLForm.tsx';
import Marquee from '../components/Marquee.tsx';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact | Ultimate Fire Protection"
  description="Get in touch with Brett at Ultimate Fire Protection. Fire suppression and alarm specialists in Hamilton, Ontario."
>

  <PageHeader
    eyebrow="Direct Line  No Sales Team"
    heading="Talk to"
    headingGold="Brett."
    sub="No call centre. No account manager. If you have a job that needs fire protection, you reach Brett directly."
    watermark="CONTACT"
    stat="24/7"
    statLabel="Emergency Line"
  />

  <!-- Quick contact strip -->
  <div class="relative z-10 border-b border-[#D4AF37]/08">
    <div class="max-w-7xl mx-auto px-8 md:px-16 py-6 flex flex-wrap gap-4">
      <a href="tel:+19056640061"
        class="inline-flex items-center gap-3 px-8 py-4 border border-[#D4AF37]/30 text-[#D4AF37] text-sm font-bold tracking-[0.15em] uppercase hover:border-[#D4AF37] hover:bg-[#D4AF37]/5 transition-all duration-200">
        ↗ (905) 664-0061
      </a>
      <a href="mailto:brett@ultimatefire.ca"
        class="inline-flex items-center gap-3 px-8 py-4 border border-[#D4AF37]/15 text-[#F5F0E8]/60 text-sm font-bold tracking-[0.15em] uppercase hover:border-[#D4AF37]/40 hover:text-[#F5F0E8] transition-all duration-200">
        ↗ brett@ultimatefire.ca
      </a>
    </div>
  </div>

  <!-- ── Marquee ── -->
  <Marquee client:load />

  <!-- ── Main Grid: Form + Sidebar ── -->
  <section class="relative z-10 py-20">
    <div class="max-w-7xl mx-auto px-8 md:px-16 grid lg:grid-cols-[1fr_380px] gap-16 xl:gap-24 items-start">

      <!-- Left: GHL Form -->
      <div>
        <ScrollReveal client:visible>
          <div class="border-l-[4px] border-[#D4AF37] pl-6 mb-12">
            <p class="text-[#A08928] text-xs font-semibold tracking-[0.35em] uppercase mb-2">Request a Consultation</p>
            <h2 class="text-[#F5F0E8] text-3xl font-black uppercase tracking-tight leading-none">
              Tell Us About Your Job
            </h2>
          </div>
        </ScrollReveal>

        <!-- GHL form embed — paste your URL in GHLForm.tsx -->
        <GHLForm client:load />
      </div>

      <!-- Right Sidebar -->
      <div class="space-y-6 lg:sticky lg:top-24">

        <!-- Direct Contact Cards -->
        <ScrollReveal client:visible>
          <div class="space-y-3">
            <a href="tel:+19056640061"
              class="group flex items-start gap-5 p-6 border border-[#D4AF37]/15 hover:border-[#D4AF37]/40 bg-[#0f0f0f] hover:bg-[#141414] transition-all duration-300 block">
              <div class="text-[#D4AF37] text-lg mt-0.5 group-hover:translate-x-0.5 transition-transform">↗</div>
              <div>
                <p class="text-[#A08928] text-[10px] font-semibold tracking-[0.3em] uppercase mb-1">Phone</p>
                <p class="text-[#F5F0E8] text-xl font-bold">(905) 664-0061</p>
                <p class="text-[#909090] text-xs mt-1">24/7 Emergency Line</p>
              </div>
            </a>

            <a href="mailto:brett@ultimatefire.ca"
              class="group flex items-start gap-5 p-6 border border-[#D4AF37]/15 hover:border-[#D4AF37]/40 bg-[#0f0f0f] hover:bg-[#141414] transition-all duration-300 block">
              <div class="text-[#D4AF37] text-lg mt-0.5 group-hover:translate-x-0.5 transition-transform">↗</div>
              <div>
                <p class="text-[#A08928] text-[10px] font-semibold tracking-[0.3em] uppercase mb-1">Email</p>
                <p class="text-[#F5F0E8] text-base font-bold break-all">brett@ultimatefire.ca</p>
                <p class="text-[#909090] text-xs mt-1">Same business day</p>
              </div>
            </a>

            <div class="flex items-start gap-5 p-6 border border-[#D4AF37]/10 bg-[#0f0f0f]">
              <div class="text-[#D4AF37] text-lg mt-0.5">◉</div>
              <div>
                <p class="text-[#A08928] text-[10px] font-semibold tracking-[0.3em] uppercase mb-1">Based In</p>
                <p class="text-[#F5F0E8] font-bold">Hamilton, Ontario</p>
                <p class="text-[#909090] text-xs mt-1">Serving Golden Horseshoe</p>
              </div>
            </div>
          </div>
        </ScrollReveal>

        <!-- Credentials -->
        <ScrollReveal client:visible>
          <div class="border border-[#D4AF37]/10 p-6 bg-[#0f0f0f]">
            <p class="text-[#A08928] text-[10px] font-semibold tracking-[0.3em] uppercase mb-5">Credentials</p>
            <div class="space-y-2.5">
              {[
                'NFPA 13 Certified Designer',
                'ULC Listed Fire Alarm Installer',
                'TSSA Licensed Fire Protection',
                'Ontario Building Code Qualified',
                'Fully Insured  $5M Liability',
              ].map((cred) => (
                <div class="flex items-center gap-3">
                  <div class="w-1 h-1 rounded-full bg-[#D4AF37] flex-shrink-0" />
                  <p class="text-[#F5F0E8]/60 text-xs">{cred}</p>
                </div>
              ))}
            </div>
          </div>
        </ScrollReveal>

        <!-- Response time -->
        <ScrollReveal client:visible>
          <div class="border border-[#D4AF37]/20 bg-[#D4AF37]/5 p-6">
            <p class="text-[#D4AF37] text-[10px] font-semibold tracking-[0.3em] uppercase mb-3">Response Time</p>
            <p class="text-[#F5F0E8] font-bold text-lg mb-1">Same Day</p>
            <p class="text-[#F5F0E8]/50 text-xs leading-relaxed">
              All consultation requests are reviewed and responded to the same business day. Emergency calls answered 24/7.
            </p>
          </div>
        </ScrollReveal>

        <!-- Service Area -->
        <ScrollReveal client:visible>
          <div class="border border-[#D4AF37]/10 p-6 bg-[#0f0f0f]">
            <p class="text-[#A08928] text-[10px] font-semibold tracking-[0.3em] uppercase mb-4">Service Area</p>
            <div class="grid grid-cols-2 gap-x-4 gap-y-2">
              {[
                'Hamilton', 'Burlington',
                'Stoney Creek', 'Oakville',
                'Brantford', 'St. Catharines',
                'Guelph', 'Niagara Region',
                'Cambridge', 'Mississauga',
              ].map((city) => (
                <p class="text-[#F5F0E8]/50 text-xs">{city}</p>
              ))}
            </div>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- ── Map ── -->
  <section class="relative z-10 border-t border-[#D4AF37]/10">
    <div class="relative h-[360px] overflow-hidden">
      <div class="absolute inset-0 z-10 pointer-events-none"
        style="background: linear-gradient(to bottom, #080808 0%, transparent 20%, transparent 80%, #080808 100%);" />
      <div class="absolute inset-0 z-10 pointer-events-none"
        style="background: linear-gradient(to right, #080808 0%, transparent 15%, transparent 85%, #080808 100%);" />
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d184551.80690539925!2d-80.08470597890623!3d43.25010499999999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x882c9ade4e26e5b5%3A0x5037b28c7231b90!2sHamilton%2C%20ON!5e0!3m2!1sen!2sca!4v1700000000000!5m2!1sen!2sca"
        width="100%"
        height="360"
        style="border:0; filter: grayscale(100%) invert(92%) contrast(75%) brightness(28%) sepia(40%) hue-rotate(185deg);"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Hamilton, Ontario service area"
      ></iframe>
    </div>
    <div class="max-w-7xl mx-auto px-8 md:px-16 py-8 flex items-center justify-between">
      <p class="text-[#909090] text-xs tracking-[0.3em] uppercase">Hamilton, Ontario · Greater Golden Horseshoe</p>
      <a href="https://maps.google.com/?q=Hamilton,Ontario" target="_blank" rel="noopener" class="text-[#A08928] text-[10px] font-semibold tracking-[0.25em] uppercase hover:text-[#D4AF37] transition-colors">
        Open in Maps →
      </a>
    </div>
  </section>

  <Footer />

</Layout>
