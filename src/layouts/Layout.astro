---
import '../styles/global.css';
import Navbar from '../components/Navbar.tsx';
import LenisProvider from '../components/LenisProvider.tsx';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ultimate Fire Protection — Hamilton's Industrial Fire Specialists",
  description = "Elite fire suppression systems for industrial and commercial infrastructure in Hamilton, Ontario.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Barlow+Condensed:wght@600;700;800;900&display=swap" rel="stylesheet" />
    <!-- Preload GLB so browser fetches it during HTML parse, before JS runs -->
    <link rel="preload" href="/red_sprinkler_pump.glb" as="fetch" crossorigin="anonymous" />
  </head>

  <body class="bg-[#080808] text-[#F5F0E8] antialiased">

    <!-- ── Page loader — inline HTML so it shows before any JS hydration ── -->
    <div id="page-loader" style="
      position: fixed; inset: 0; z-index: 99999;
      background: #080808;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      transition: opacity 0.7s ease;
    ">
      <!-- Brand -->
      <div style="text-align:center; margin-bottom: 2.5rem;">
        <p style="
          font-family: 'Barlow Condensed', 'Inter', sans-serif;
          font-size: 1.25rem; font-weight: 700;
          color: #D4AF37; letter-spacing: 0.35em;
          text-transform: uppercase; margin: 0 0 0.5rem;
        ">Ultimate Fire Protection</p>
        <p style="
          font-family: 'Inter', sans-serif;
          font-size: 0.6rem; font-weight: 600;
          color: #6B5010; letter-spacing: 0.45em;
          text-transform: uppercase; margin: 0;
        ">Hamilton · Est. 2003</p>
      </div>

      <!-- Progress track -->
      <div style="
        width: 180px; height: 1px;
        background: rgba(212,175,55,0.15);
        position: relative; overflow: hidden;
      ">
        <div id="loader-bar" style="
          position: absolute; left: 0; top: 0;
          height: 100%; width: 0%;
          background: linear-gradient(to right, #D4AF37, #F7E98E);
          transition: width 0.15s linear;
        "></div>
      </div>
    </div>

    <script>
      (function () {
        const loader = document.getElementById('page-loader');
        const bar    = document.getElementById('loader-bar');
        if (!loader || !bar) return;

        // Animate bar to ~88% while waiting for load, then snap to 100% and fade
        let p = 0;
        const tick = setInterval(() => {
          p = p + (88 - p) * 0.04;
          bar.style.width = p.toFixed(1) + '%';
        }, 40);

        const done = () => {
          clearInterval(tick);
          bar.style.width = '100%';
          setTimeout(() => {
            loader.style.opacity = '0';
            setTimeout(() => { loader.style.display = 'none'; }, 750);
          }, 250);
        };

        if (document.readyState === 'complete') {
          done();
        } else {
          window.addEventListener('load', done, { once: true });
          setTimeout(done, 6000); // hard cap — never block longer than 6s
        }
      })();
    </script>

    <!-- Lenis smooth scroll -->
    <LenisProvider client:load />

    <!-- Navbar -->
    <Navbar client:load />

    <!-- Layer 0 — Depth field -->
    <div class="depth-field" aria-hidden="true"></div>

    <!-- Content -->
    <slot />

  </body>
</html>

<style>
  .depth-field {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse 140% 90% at 50% 35%,
      #141414 0%,
      #0d0d0d 35%,
      #080808 100%
    );
  }

  :global(section),
  :global(main),
  :global(header),
  :global(footer) {
    position: relative;
    z-index: 10;
  }
</style>
