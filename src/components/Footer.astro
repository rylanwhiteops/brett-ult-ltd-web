---
---

<footer class="relative z-10 border-t border-[#D4AF37]/10 py-14">
  <div class="max-w-7xl mx-auto px-8 md:px-16">

    <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-10">

      <!-- Left: Logo + tagline -->
      <div class="flex flex-col items-center md:items-start gap-5">
        <div class="flex items-center gap-3">
          <svg width="44" height="50" viewBox="0 0 36 44" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 2L3 8v14c0 9 6.5 17 15 20 8.5-3 15-11 15-20V8L18 2z"
              fill="rgba(212,175,55,0.06)" stroke="#D4AF37" stroke-width="1.2" stroke-linejoin="round"/>
            <path d="M18 10c-3 4.5-4.5 7.5-4.5 10a4.5 4.5 0 0 0 9 0c0-2.5-1.5-5.5-4.5-10z"
              fill="#D4AF37" opacity="0.9"/>
            <path d="M18 15c-1.2 2-1.8 3.5-1.8 5a1.8 1.8 0 0 0 3.6 0c0-1.5-.6-3-1.8-5z"
              fill="#f7e98e" opacity="0.8"/>
          </svg>
          <div class="leading-none">
            <p class="text-[#D4AF37] text-sm font-black tracking-[0.22em] uppercase">ULTIMATE</p>
            <p class="text-[#F5F0E8]/30 text-[9px] tracking-[0.3em] uppercase mt-1">Fire Protection</p>
          </div>
        </div>
        <p class="text-[#909090] text-[10px] tracking-[0.25em] uppercase max-w-[220px] text-center md:text-left leading-relaxed">
          Ontario's Industrial Fire Specialists  Est. 2020
        </p>
      </div>

      <!-- Middle: Quick links -->
      <div class="flex flex-col items-center md:items-start gap-3">
        <p class="text-[#A08928] text-[9px] font-semibold tracking-[0.4em] uppercase mb-1">Pages</p>
        {['/', '/projects', '/services', '/careers', '/contact'].map((href, i) => (
          <a
            href={href}
            class="text-[#909090] text-xs tracking-[0.2em] uppercase hover:text-[#D4AF37] transition-colors duration-200"
          >
            {['Home', 'Projects', 'Services', 'Careers', 'Contact'][i]}
          </a>
        ))}
      </div>

      <!-- Right: Contact -->
      <div class="flex flex-col items-center md:items-end gap-3">
        <p class="text-[#A08928] text-[9px] font-semibold tracking-[0.4em] uppercase mb-1">Direct Line</p>
        <a href="tel:+19056640061" class="text-[#F5F0E8]/60 text-sm font-bold hover:text-[#D4AF37] transition-colors">(905) 664-0061</a>
        <a href="mailto:brett@ultimatefire.ca" class="text-[#909090] text-xs hover:text-[#F5F0E8]/60 transition-colors">brett@ultimatefire.ca</a>
        <p class="text-[#909090] text-[10px] tracking-[0.2em] uppercase mt-2">590 South Service Rd, Stoney Creek, ON</p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-[#D4AF37]/8 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-[#909090] text-[10px] tracking-[0.25em] uppercase">
        © 2026 Ultimate Fire Protection Ltd.
      </p>
      <p class="text-[#909090] text-[10px] tracking-[0.2em] uppercase">
        Licensed &nbsp;|&nbsp; Insured &nbsp;|&nbsp; NFPA Certified &nbsp;|&nbsp; TSSA Approved
      </p>
    </div>

    <!-- Model attribution -->
    <p class="mt-4 text-center" style="font-size:11px; color:#444444; line-height:1.6;">
      <a href="https://skfb.ly/6X6vU" target="_blank" rel="noopener noreferrer" style="color:#555555; text-decoration:underline;">"Red Sprinkler Pump"</a>
      {' '}by ccych is licensed under{' '}
      <a href="http://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener noreferrer" style="color:#555555; text-decoration:underline;">Creative Commons Attribution</a>.
    </p>
  </div>
</footer>
