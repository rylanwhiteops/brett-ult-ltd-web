---
import EmberAnimation from './EmberAnimation.tsx';
import HeroHeadline from './HeroHeadline.tsx';
import SprinklerModel from './SprinklerModel.tsx';
---

<section id="hero" class="relative min-h-screen overflow-hidden">

  <!-- Ember particles — absolute, clipped to hero -->
  <EmberAnimation client:load />

  <!-- Bottom vignette — text legibility -->
  <div class="absolute inset-0 z-[1] pointer-events-none"
    style="background: linear-gradient(to top, rgba(8,8,8,0.70) 0%, transparent 45%);">
  </div>

  <!-- ── Desktop layout: copy left + model right ── -->
  <div class="relative z-[2] hidden md:flex items-center min-h-screen max-w-[1500px] mx-auto w-full px-8 md:px-16 lg:px-24 pt-20 pb-12">

    <!-- Left: Copy (60% width) -->
    <div class="flex flex-col justify-center flex-1 min-w-0 py-8 pr-8 lg:pr-16">

      <div class="flex items-center gap-4 mb-8">
        <span class="block w-8 h-px bg-[#D4AF37]/50"></span>
        <p class="eyebrow text-[#A08928]">Hamilton, Ontario · Est. 2003</p>
      </div>

      <!-- Radial glow behind headline -->
      <div class="relative">
        <div
          class="absolute pointer-events-none"
          style="inset: -30% -20%; background: radial-gradient(ellipse 65% 55% at 40% 50%, rgba(212,175,55,0.07) 0%, rgba(212,160,23,0.03) 40%, transparent 70%); z-index: 0;"
          aria-hidden="true"
        ></div>
        <div class="relative z-[1]">
          <HeroHeadline client:load />
        </div>
      </div>

      <p class="text-[#F5F0E8]/60 text-base md:text-lg max-w-md leading-relaxed mb-10 font-sans">
        Hamilton's elite fire suppression for industrial &amp;<br />
        commercial infrastructure.
      </p>

      <div class="flex flex-wrap gap-4 mb-14">
        <a href="/contact"
          class="inline-flex items-center gap-3 px-10 py-4 text-sm font-bold tracking-[0.2em] uppercase text-[#080808] bg-[#D4AF37] hover:bg-[#f7e98e] transition-colors duration-300">
          Request Consultation
        </a>
        <a href="/projects"
          class="inline-flex items-center gap-3 px-10 py-4 text-sm font-bold tracking-[0.2em] uppercase text-[#D4AF37] border border-[#D4AF37]/30 hover:border-[#D4AF37] transition-colors duration-300">
          View Our Work
        </a>
      </div>

      <div class="flex flex-wrap gap-x-8 gap-y-3">
        {['NFPA 13', 'TSSA Licensed', 'ULC Listed', '500+ Installations', '24/7 Response'].map(tag => (
          <span class="eyebrow text-[#6B6B6B]">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Right: 3D Sprinkler Pump (~40% width) -->
    <div class="flex-shrink-0 w-[40%] max-w-[600px]" style="height: 75vh; min-height: 500px;">
      <SprinklerModel client:load />
    </div>

  </div>

  <!-- ── Mobile layout: copy top + model below ── -->
  <div class="relative z-[2] flex md:hidden flex-col min-h-screen px-6 pt-24 pb-12">

    <!-- Copy -->
    <div class="flex flex-col justify-center flex-shrink-0 pb-6">
      <div class="flex items-center gap-4 mb-6">
        <span class="block w-6 h-px bg-[#D4AF37]/50"></span>
        <p class="eyebrow text-[#A08928]">Hamilton, Ontario · Est. 2003</p>
      </div>

      <div class="relative mb-6">
        <div
          class="absolute pointer-events-none"
          style="inset: -20% -10%; background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(212,175,55,0.07) 0%, transparent 70%); z-index: 0;"
          aria-hidden="true"
        ></div>
        <div class="relative z-[1]">
          <HeroHeadline client:load />
        </div>
      </div>

      <p class="text-[#F5F0E8]/60 text-base leading-relaxed mb-8 font-sans">
        Hamilton's elite fire suppression for industrial &amp; commercial infrastructure.
      </p>

      <div class="flex flex-col gap-3 mb-10">
        <a href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 text-sm font-bold tracking-[0.2em] uppercase text-[#080808] bg-[#D4AF37] hover:bg-[#f7e98e] transition-colors duration-300">
          Request Consultation
        </a>
        <a href="/projects"
          class="inline-flex items-center justify-center px-8 py-4 text-sm font-bold tracking-[0.2em] uppercase text-[#D4AF37] border border-[#D4AF37]/30 hover:border-[#D4AF37] transition-colors duration-300">
          View Our Work
        </a>
      </div>
    </div>

    <!-- Model — below headline on mobile -->
    <div class="flex-1 w-full" style="min-height: 280px; max-height: 380px;">
      <SprinklerModel client:visible />
    </div>

    <!-- Credential strip at bottom -->
    <div class="flex-shrink-0 pt-4 flex flex-wrap gap-x-6 gap-y-2">
      {['NFPA 13', 'TSSA Licensed', 'ULC Listed', '24/7 Response'].map(tag => (
        <span class="eyebrow text-[#6B6B6B]">{tag}</span>
      ))}
    </div>
  </div>

</section>

<style>
  @keyframes shimmer {
    0%   { background-position: 250% center; }
    100% { background-position: -250% center; }
  }
</style>
