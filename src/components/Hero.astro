---
import EmberAnimation from './EmberAnimation.tsx';
import HeroHeadline from './HeroHeadline.tsx';
import SprinklerModel from './SprinklerModel.tsx';
---

<section id="hero" class="relative min-h-screen overflow-hidden bg-[#0a0a0a]">

  <!-- Ember particles — absolute, clipped to hero, z:0 -->
  <EmberAnimation client:load />

  <!-- Very subtle bottom fade — keeps ember-to-section transition clean -->
  <div
    class="absolute inset-x-0 bottom-0 h-40 z-[1] pointer-events-none"
    style="background: linear-gradient(to top, #0a0a0a 0%, transparent 100%);"
    aria-hidden="true"
  ></div>

  <!-- ── Desktop layout ──────────────────────────────── -->
  <div class="relative z-[2] hidden md:flex items-center min-h-screen max-w-[1600px] mx-auto w-full">

    <!-- Left 40%: Copy — vertically centered -->
    <div class="w-[40%] flex flex-col justify-center px-16 lg:px-24 py-28 flex-shrink-0">

      <!-- Eyebrow -->
      <div class="flex items-center gap-4 mb-8">
        <span class="block w-8 h-px bg-[#D4AF37]/50"></span>
        <p class="eyebrow text-[#A08928]">Hamilton, Ontario · Est. 2003</p>
      </div>

      <!-- Headline with radial glow behind -->
      <div class="relative mb-6">
        <div
          class="absolute pointer-events-none"
          style="inset: -35% -15%; background: radial-gradient(ellipse 70% 60% at 35% 50%, rgba(212,175,55,0.08) 0%, rgba(212,160,23,0.03) 45%, transparent 72%); z-index: 0;"
          aria-hidden="true"
        ></div>
        <div class="relative z-[1]">
          <HeroHeadline client:load />
        </div>
      </div>

      <!-- Sub -->
      <p class="text-[#F5F0E8]/55 text-base md:text-lg max-w-sm leading-relaxed mb-10 font-sans">
        Hamilton's elite fire suppression for industrial &amp; commercial infrastructure.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 mb-14">
        <a
          href="/contact"
          class="inline-flex items-center px-10 py-4 text-sm font-bold tracking-[0.2em] uppercase text-[#0a0a0a] bg-[#D4AF37] hover:bg-[#f7e98e] transition-colors duration-300"
        >
          Request Consultation
        </a>
        <a
          href="/projects"
          class="inline-flex items-center px-10 py-4 text-sm font-bold tracking-[0.2em] uppercase text-[#D4AF37] border border-[#D4AF37]/30 hover:border-[#D4AF37] transition-colors duration-300"
        >
          View Our Work
        </a>
      </div>

      <!-- Credential strip -->
      <div class="flex flex-wrap gap-x-7 gap-y-3">
        {['NFPA 13', 'TSSA Licensed', 'ULC Listed', '500+ Installs', '24/7 Response'].map(tag => (
          <span class="eyebrow text-[#555]">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Right 60%: 3D Model — dominant, full hero height -->
    <div class="flex-1 self-stretch relative">
      <SprinklerModel client:load />
    </div>

  </div>

  <!-- ── Mobile layout ──────────────────────────────── -->
  <div class="relative z-[2] flex md:hidden flex-col min-h-screen px-6 pt-24 pb-10">

    <!-- Copy block -->
    <div class="flex flex-col flex-shrink-0 pb-4">
      <div class="flex items-center gap-3 mb-6">
        <span class="block w-6 h-px bg-[#D4AF37]/50"></span>
        <p class="eyebrow text-[#A08928]">Hamilton · Est. 2003</p>
      </div>

      <div class="relative mb-5">
        <div
          class="absolute pointer-events-none"
          style="inset: -20% -10%; background: radial-gradient(ellipse 80% 65% at 45% 50%, rgba(212,175,55,0.07) 0%, transparent 70%); z-index:0;"
          aria-hidden="true"
        ></div>
        <div class="relative z-[1]">
          <HeroHeadline client:load />
        </div>
      </div>

      <p class="text-[#F5F0E8]/55 text-sm leading-relaxed mb-7 font-sans max-w-[320px]">
        Hamilton's elite fire suppression for industrial &amp; commercial infrastructure.
      </p>

      <div class="flex flex-col gap-3 mb-8">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-sm font-bold tracking-[0.18em] uppercase text-[#0a0a0a] bg-[#D4AF37] hover:bg-[#f7e98e] transition-colors">
          Request Consultation
        </a>
        <a href="/projects" class="inline-flex items-center justify-center px-8 py-4 text-sm font-bold tracking-[0.18em] uppercase text-[#D4AF37] border border-[#D4AF37]/30 hover:border-[#D4AF37] transition-colors">
          View Our Work
        </a>
      </div>
    </div>

    <!-- Model: scaled down, centered below headline -->
    <div class="flex-1 w-full" style="min-height: 300px; max-height: 400px;">
      <SprinklerModel client:visible />
    </div>

    <!-- Credentials at very bottom -->
    <div class="flex-shrink-0 pt-3 flex flex-wrap gap-x-5 gap-y-2">
      {['NFPA 13', 'TSSA Licensed', 'ULC Listed', '24/7'].map(tag => (
        <span class="eyebrow text-[#444]">{tag}</span>
      ))}
    </div>
  </div>

</section>

<style>
  @keyframes shimmer {
    0%   { background-position: 250% center; }
    100% { background-position: -250% center; }
  }
</style>
