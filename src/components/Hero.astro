---
import EmberAnimation from './EmberAnimation.tsx';
import HeroHeadline from './HeroHeadline.tsx';
import SprinklerModel from './SprinklerModel.tsx';
---

<!--
  overflow: clip — clips children without creating a scroll container
  (overflow: hidden creates a containing block that breaks GSAP fixed-pin)
-->
<section id="hero" class="relative min-h-screen bg-[#0a0a0a]" style="overflow: clip;">

  <!-- Ember particles — absolute, z:0, clipped by section overflow -->
  <EmberAnimation client:load />

  <!-- Bottom edge fade — clean transition into stats section -->
  <div
    class="absolute inset-x-0 bottom-0 h-48 z-[1] pointer-events-none"
    style="background: linear-gradient(to top, #080808 30%, transparent);"
    aria-hidden="true"
  ></div>


  <!--
    3D model — always full-screen, z:1.
    Camera starts offset-right so model reads as right-column at rest.
    No container resize during scroll → no aspect-ratio pop.
  -->
  <div
    id="model-container"
    class="hidden md:block"
    style="position:absolute; inset:0; z-index:1; pointer-events:none;"
    aria-hidden="true"
  >
    <SprinklerModel client:load />
  </div>

  <!--
    Gradient mask — covers left half behind copy so model doesn't clash with text.
    Fades out as copy slides away on scroll (driven by SprinklerModel onUpdate).
  -->
  <div
    id="model-mask"
    class="hidden md:block absolute inset-y-0 left-0 pointer-events-none"
    style="width:60%; z-index:2; background: linear-gradient(to right, #0a0a0a 50%, transparent 100%);"
    aria-hidden="true"
  ></div>

  <!-- ── Desktop: copy (in-flow so section has definite height) ── -->
  <div class="hidden md:flex relative z-[3] items-center min-h-screen w-full pointer-events-none">

    <!-- Left copy — id="hero-copy" so GSAP can fade it -->
    <div
      id="hero-copy"
      class="w-[46%] flex-shrink-0 flex flex-col justify-center pl-20 lg:pl-28 xl:pl-36 pr-10 py-20 pointer-events-auto"
      style="will-change: opacity, transform;"
    >
      <!-- Brand lockup — fills dead space above headline -->
      <div class="flex items-center gap-4 mb-14">
        <svg width="40" height="46" viewBox="0 0 36 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 2L3 8v14c0 9 6.5 17 15 20 8.5-3 15-11 15-20V8L18 2z"
            fill="rgba(212,175,55,0.06)" stroke="#D4AF37" stroke-width="1.2" stroke-linejoin="round"/>
          <path d="M18 10c-3 4.5-4.5 7.5-4.5 10a4.5 4.5 0 0 0 9 0c0-2.5-1.5-5.5-4.5-10z"
            fill="#D4AF37" opacity="0.9"/>
          <path d="M18 15c-1.2 2-1.8 3.5-1.8 5a1.8 1.8 0 0 0 3.6 0c0-1.5-.6-3-1.8-5z"
            fill="#f7e98e" opacity="0.8"/>
        </svg>
        <div class="leading-none">
          <p class="text-[#D4AF37] text-base font-black tracking-[0.22em] uppercase">ULTIMATE</p>
          <p class="text-[#F5F0E8]/30 text-[10px] tracking-[0.3em] uppercase mt-1">Fire Protection</p>
        </div>
      </div>

      <!-- Eyebrow -->
      <div class="flex items-center gap-4 mb-7">
        <span class="block w-8 h-px bg-[#D4AF37]/50"></span>
        <p class="eyebrow text-[#A08928]">Hamilton, Ontario  Est. 2003</p>
      </div>

      <!-- Headline + glow -->
      <div class="relative mb-5">
        <div
          class="absolute pointer-events-none"
          style="inset: -40% -10%; background: radial-gradient(ellipse 80% 65% at 35% 50%, rgba(212,175,55,0.09) 0%, rgba(212,160,23,0.03) 45%, transparent 70%); z-index:0;"
          aria-hidden="true"
        ></div>
        <div style="position:relative; z-index:1; overflow:visible;">
          <HeroHeadline client:load />
        </div>
      </div>

      <!-- Subtext -->
      <p class="body-copy text-lg max-w-[400px] mb-9 font-sans">
        Hamilton's elite fire suppression for industrial &amp; commercial infrastructure.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap sm:flex-nowrap gap-4 mb-12">
        <a
          href="/contact"
          class="inline-flex items-center px-10 py-5 text-sm font-bold tracking-[0.2em] uppercase text-[#0a0a0a] bg-[#D4AF37] hover:bg-[#f7e98e] transition-colors duration-300"
        >
          Request Consultation
        </a>
        <a
          href="/projects"
          class="inline-flex items-center px-10 py-5 text-sm font-bold tracking-[0.2em] uppercase text-[#D4AF37] border border-[#D4AF37]/30 hover:border-[#D4AF37] transition-colors duration-300"
        >
          View Our Work
        </a>
      </div>

      <!-- Credentials -->
      <div class="flex flex-wrap gap-x-6 gap-y-3">
        {['NFPA 13', 'TSSA Licensed', 'ULC Listed', '500+ Installs', '24/7 Response'].map(tag => (
          <span class="eyebrow text-[#909090]">{tag}</span>
        ))}
      </div>
    </div>

  </div>

  <!-- ── Mobile: stacked copy ──────────────────────────── -->
  <div class="relative z-[2] flex md:hidden flex-col justify-center min-h-screen px-6 pt-16 pb-12">

    <!-- Eyebrow -->
    <div class="flex items-center gap-3 mb-4">
      <span class="block w-6 h-px bg-[#D4AF37]/50"></span>
      <p class="eyebrow text-[#A08928]">Hamilton  Est. 2003</p>
    </div>

    <!-- Headline -->
    <div style="position:relative; overflow:visible; margin-bottom:1rem;">
      <div style="position:relative; z-index:1; overflow:visible;">
        <HeroHeadline client:load />
      </div>
    </div>

    <!-- Subtext -->
    <p class="body-copy text-sm mb-7 font-sans max-w-[300px]">
      Hamilton's elite fire suppression for industrial &amp; commercial infrastructure.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col gap-3 mb-8">
      <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-sm font-bold tracking-[0.18em] uppercase text-[#0a0a0a] bg-[#D4AF37] hover:bg-[#f7e98e] transition-colors">
        Request Consultation
      </a>
      <a href="/projects" class="inline-flex items-center justify-center px-8 py-4 text-sm font-bold tracking-[0.18em] uppercase text-[#D4AF37] border border-[#D4AF37]/30 hover:border-[#D4AF37] transition-colors">
        View Our Work
      </a>
    </div>

    <!-- Credentials — directly below CTAs, no floating to bottom -->
    <div class="flex flex-wrap gap-x-5 gap-y-2">
      {['NFPA 13', 'TSSA Licensed', 'ULC Listed', '24/7'].map(tag => (
        <span class="eyebrow text-[#909090]">{tag}</span>
      ))}
    </div>
  </div>

</section>

<style>
  @keyframes shimmer {
    0%   { background-position: 250% center; }
    100% { background-position: -250% center; }
  }
</style>
