---
import ExpertiseCard from './ExpertiseCard.tsx';

const services = [
  {
    title: 'Fire Suppression Systems',
    description: 'Full design, supply and installation of wet pipe, dry pipe, pre-action and deluge suppression systems for industrial and commercial occupancies.',
    icon: `<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 2C8 6 6 9 6 12a6 6 0 0 0 12 0c0-3-2-6-6-10z"/>
      <path d="M12 12c0 2-1.5 3-1.5 3"/>
    </svg>`,
  },
  {
    title: 'Sprinkler System Design',
    description: 'NFPA 13 compliant hydraulic calculations and layout for warehouses, manufacturing floors, high-piled storage and multi-storey commercial builds.',
    icon: `<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="8" r="2"/>
      <path d="M12 10v4"/>
      <path d="M8 16l1.5-2M16 16l-1.5-2M12 18v2"/>
      <path d="M6 18l1-2M18 18l-1-2"/>
    </svg>`,
  },
  {
    title: 'Fire Alarm Systems',
    description: 'ULC-listed detection, notification and monitoring systems. From single-panel retrofits to addressable multi-building networked installations.',
    icon: `<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>`,
  },
  {
    title: 'Annual Inspections & Certification',
    description: 'Scheduled inspection programs for sprinklers, standpipes, fire pumps, suppression agents and alarm panels — fully documented for insurance and AHJ.',
    icon: `<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M9 11l3 3L22 4"/>
      <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
    </svg>`,
  },
  {
    title: 'Emergency 24/7 Response',
    description: 'Around-the-clock emergency repair and impairment management. We keep your system operational and your occupancy permit intact.',
    icon: `<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 6v6l4 2"/>
    </svg>`,
  },
  {
    title: 'Industrial & High-Hazard',
    description: 'Specialty suppression for paint booths, chemical storage, server rooms and high-challenge occupancies requiring foam, clean agent or CO₂ systems.',
    icon: `<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <rect x="2" y="7" width="20" height="14" rx="2"/>
      <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
      <path d="M12 12v4M10 14h4"/>
    </svg>`,
  },
];
---

<section id="expertise" class="relative z-10 section-gap--lg">
  <div class="max-w-7xl mx-auto px-8 md:px-16">

    <!-- Section header — 4px gold bar, hard left -->
    <div class="mb-16 md:mb-20 border-l-[4px] border-[#D4AF37] pl-6">
      <p class="text-[#A08928] text-xs font-semibold tracking-[0.35em] uppercase mb-4">
        Core Expertise
      </p>
      <h2 class="text-[#F5F0E8] text-4xl md:text-5xl font-black uppercase tracking-tight leading-none">
        Built for the<br />
        <span class="text-[#D4AF37]">Hard Jobs.</span>
      </h2>
    </div>

    <!-- Hard grid — zero gap, borders form the structure -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service, i) => (
        <ExpertiseCard
          client:visible
          icon={service.icon}
          title={service.title}
          description={service.description}
          index={i}
        />
      ))}
    </div>

  </div>
</section>
